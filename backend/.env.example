# ================================
# SUPABASE (free at supabase.com)
# ================================
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ================================
# GROQ (free at console.groq.com)
# ================================
GROQ_API_KEY=your_groq_api_key_here

# ================================
# GEMINI (free at aistudio.google.com)
# ================================
GEMINI_API_KEY=your_gemini_api_key_here

# ================================
# APP CONFIG
# ================================
# Which LLM to use: "groq_llama", "groq_mixtral", "groq_gemma", "gemini_flash"
ACTIVE_LLM=groq_llama

# Which embedding model: "gemini" or "local" (local = free, no API needed)
EMBEDDING_MODEL=gemini

# Frontend URL for CORS (your Vercel URL)
FRONTEND_URL=http://localhost:3000
